# Database
DATABASE_URL="mysql://username:password@localhost:3306/itechs_learning"

# JWT
JWT_SECRET="your-super-secure-jwt-secret-key-change-in-production"
JWT_EXPIRE_TIME="7d"

# Server
PORT=5001
NODE_ENV="development"
# Optional: comma-separated extra web origins (localhost origins are auto-allowed)
CORS_ALLOWED_ORIGINS=""

# Email Configuration (for OTP)
EMAIL_FROM="noreply@itechs.edu"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Provider (supported: gemini, deepseek)
AI_PROVIDER="gemini"

# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_MODEL="deepseek-chat"
# Optional: base URL (service appends /chat/completions when needed)
DEEPSEEK_API_URL="https://api.deepseek.com/v1"

# Gemini
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"
# Optional: override Gemini base URL only if needed
GEMINI_API_URL="https://generativelanguage.googleapis.com/v1beta/models"
# Optional: backend timeout per Gemini request in milliseconds
GEMINI_REQUEST_TIMEOUT_MS=60000
# Optional: gameplay dynamic-question timeout fallback in milliseconds
GEMINI_DYNAMIC_QUESTION_TIMEOUT_MS=55000
# Optional: cap Gemini output tokens per request (helps avoid truncated JSON)
GEMINI_MAX_OUTPUT_TOKENS=5000

# Dynamic question cache and persistent pool controls
# Reuse generated questions briefly in memory (set 0 to disable)
DYNAMIC_QUESTION_CACHE_TTL_MS=600000
# Persist generated variants and assign one per student login session
DYNAMIC_QUESTION_POOL_PERSISTENCE_ENABLED=true
# Keep generated variants reusable for this long (milliseconds)
DYNAMIC_QUESTION_POOL_TTL_MS=259200000
# Keep student login-session assignments stable for this long (milliseconds)
DYNAMIC_QUESTION_ASSIGNMENT_TTL_MS=86400000
# Max persistent candidates inspected per assignment
DYNAMIC_QUESTION_POOL_CANDIDATE_LIMIT=20
# Avoid assigning the most recently used N variants to the same student
DYNAMIC_QUESTION_RECENT_EXCLUSIONS=3
# Minimum interval between lightweight pool prune passes (milliseconds)
DYNAMIC_QUESTION_POOL_PRUNE_INTERVAL_MS=60000

# Default Super Admin (create on first run)
SUPER_ADMIN_EMAIL="admin@itechs.edu"
SUPER_ADMIN_PASSWORD="Admin@123"